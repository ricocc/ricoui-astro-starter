---
import Button from "@/components/ui/Button.astro";
import Badge from "@/components/ui/Badge.astro";
import BrowserFrame from "@/components/ui/BrowserFrame.astro";
import { siteConfig } from "@/config/site";
import { FileText, GitFork, Layers, Palette } from "@lucide/astro";

const tokens = [
  { name: "primary", value: "var(--color-primary)", token: "--color-primary" },
  { name: "canvas", value: "var(--color-bg-primary)", token: "--color-bg-primary" },
  { name: "accent", value: "var(--color-accent)", token: "--color-accent" },
  { name: "dark", value: "var(--color-bg-primary-dark)", token: "--color-bg-primary-dark" },
];

const routes = ["/", "/blog", "/design", "/elements"];
---

<section class="relative z-20 site-container pt-16 md:pt-24 lg:pt-32">
	<div class="grid items-center gap-12 lg:grid-cols-[1.02fr_0.98fr]">
		<div>
			<div class="mb-6 flex flex-wrap gap-2">
				<Badge variant="primary">Design-led starter</Badge>
				<Badge variant="accent">Astro + Blog + Elements</Badge>
			</div>

			<h1 class="mb-5 max-w-3xl text-4xl leading-tight md:text-5xl lg:text-6xl font-brand">
				A clean Astro starter shaped by a real design system
			</h1>

			<p class="mb-7 max-w-2xl text-base md:text-lg text-neutral-600 dark:text-neutral-300 leading-relaxed">
				Use the RicoUI visual theme, DESIGN.md guidance, and ready Blog foundation to build your own site without carrying demo product clutter into the project.
			</p>

			<div class="flex flex-wrap gap-3">
				<Button url="/design" type="fill">
					<FileText size={16} /> View DESIGN.md
				</Button>
				<Button url="/elements">
					<Layers size={16} /> Browse Elements
				</Button>
				<Button url={siteConfig.social.github} type="outline" target="_blank">
					<GitFork size={16} /> GitHub
				</Button>
			</div>
		</div>

		<div class="relative">
			<BrowserFrame url="ricoui.com/templates">
				<div class="min-h-[340px] p-5 md:p-6">
					<div class="mb-5 flex items-center justify-between gap-4">
						<div class="flex items-center gap-2">
							<div class="grid h-9 w-9 place-items-center rounded-lg bg-primary/10 text-primary">
								<Palette class="h-4 w-4" />
							</div>
							<div>
								<p class="text-sm font-semibold text-neutral-800 dark:text-neutral-100">Theme console</p>
								<p class="text-xs text-neutral-400">tokens stay readable</p>
							</div>
						</div>
						<span class="rounded-md border border-dashed border-primary/25 px-2 py-1 text-[10px] font-medium text-primary">
							v1.0
						</span>
					</div>

					<div class="grid grid-cols-2 gap-3">
						{tokens.map((token, index) => (
							<div
								class="rounded-lg border border-primary/10 bg-bg-primary/50 p-3 dark:border-neutral-700 dark:bg-neutral-800/40"
								style={`--token-delay: ${index * 120}ms;`}
							>
								<div
									class:list={["hero-token-swatch", "mb-4 h-16 rounded-md border border-white/60 shadow-sm dark:border-white/10"]}
									style={`background: ${token.value}`}
								></div>
								<p class="text-xs font-semibold text-neutral-700 dark:text-neutral-200">{token.name}</p>
								<p class="font-mono text-[11px] text-neutral-400" data-token-value={token.token}>{token.token}</p>
							</div>
						))}
					</div>

					<div class="mt-4 rounded-lg border border-dashed border-primary/15 bg-bg-secondary/60 p-3 dark:border-neutral-700 dark:bg-neutral-900/40">
						<p class="mb-3 text-[10px] uppercase tracking-[0.16em] text-neutral-400">starter routes</p>
						<div class="grid grid-cols-2 gap-2">
							{routes.map((route) => (
								<div class="rounded-md bg-primary/5 px-3 py-2 font-mono text-xs text-primary dark:bg-primary/10 dark:text-primary-light">
									{route}
								</div>
							))}
						</div>
					</div>
				</div>
			</BrowserFrame>
		</div>
	</div>
</section>

<style>
	.hero-token-swatch {
		animation: token-rise 560ms cubic-bezier(0.4, 0, 0.2, 1) backwards;
		animation-delay: var(--token-delay, 0ms);
	}

	@keyframes token-rise {
		from {
			opacity: 0;
			transform: translateY(8px) scale(0.98);
		}
		to {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.hero-token-swatch {
			animation: none !important;
		}
	}
</style>

<script>
	function syncHeroTokenValues() {
		const styles = getComputedStyle(document.documentElement);
		document.querySelectorAll<HTMLElement>('[data-token-value]').forEach((node) => {
			const token = node.dataset.tokenValue;
			if (!token) return;
			node.textContent = styles.getPropertyValue(token).trim() || token;
		});
	}

	document.addEventListener("DOMContentLoaded", syncHeroTokenValues);
	window.addEventListener("themechange", syncHeroTokenValues);
</script>
