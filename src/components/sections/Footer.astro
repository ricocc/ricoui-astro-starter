---
import Logo from "@/components/ui/Logo.astro";
import ToTop from "@/components/widgets/ToTop.astro";
import { siteConfig, socialLinks } from "@/config/site.js";

const currentYear = new Date().getFullYear();

const footerLinks = {
	starter: [
		{ name: "Home", url: "/" },
		{ name: "Blog", url: "/blog" },
		{ name: "DESIGN.md", url: "/design" },
		{ name: "Elements", url: "/elements" },
	],
	resources: [
		{ name: "RSS", url: "/rss.xml" },
		{ name: "GitHub", url: siteConfig.social.github },
		{ name: "MIT License", url: `${siteConfig.social.github}/blob/main/LICENSE` },
	],
};

const templateVersion = "v1.0.0";
---

<section
	class="mt-20 border-t border-dashed border-primary/15 text-gray-700 dark:border-primary-dark/15 md:mt-32"
>
	<div class="container mx-auto max-w-7xl px-7 py-12 md:py-16">
		<div class="mb-10 flex flex-col gap-8 md:flex-row md:items-start md:justify-between">
			<div class="max-w-sm">
				<Logo />
				<p class="mt-4 text-sm leading-relaxed text-neutral-500 dark:text-neutral-400">
					A design-led Astro starter with Blog, DESIGN.md, Elements, Tailwind CSS v4, and a reusable RicoUI theme.
				</p>
			</div>

			<div class="grid grid-cols-2 gap-8 md:gap-12">
				<div>
					<h4 class="mb-4 text-sm font-semibold text-neutral-800 dark:text-neutral-200">Starter</h4>
					<ul class="space-y-3">
						{footerLinks.starter.map((link) => (
							<li>
								<a href={link.url} class="text-sm text-neutral-500 transition-colors duration-200 hover:text-primary dark:text-neutral-400 dark:hover:text-primary-light">
									{link.name}
								</a>
							</li>
						))}
					</ul>
				</div>

				<div>
					<h4 class="mb-4 text-sm font-semibold text-neutral-800 dark:text-neutral-200">Resources</h4>
					<ul class="space-y-3">
						{footerLinks.resources.map((link) => (
							<li>
								<a href={link.url} class="text-sm text-neutral-500 transition-colors duration-200 hover:text-primary dark:text-neutral-400 dark:hover:text-primary-light">
									{link.name}
								</a>
							</li>
						))}
					</ul>
				</div>
			</div>
		</div>

		<div class="flex flex-col items-center justify-between gap-4 border-t border-dashed border-primary/10 pt-8 dark:border-primary-dark/10 sm:flex-row">
			<p class="text-sm text-neutral-400 dark:text-neutral-500">
				© {currentYear}
				<a href={siteConfig.url || " "} target="_blank" class="hover:text-primary dark:hover:text-primary-light">
					{siteConfig.author || "RicoUI"}
				</a>.
				Released under the MIT License.
			</p>

			<div class="flex items-center gap-4">
				<span class="inline-flex items-center gap-2 text-xs text-neutral-400 dark:text-neutral-500">
					<span class="inline-flex items-center gap-1.5 rounded-md border border-dashed border-primary/30 px-2 py-0.5 text-primary/80">
						<span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
						{templateVersion}
					</span>
					<span>Astro starter</span>
				</span>
				<span class="inline-flex justify-center space-x-4">
					{socialLinks.map((social) => (
						<a
							href={social.url}
							target="_blank"
							class="footer-social-icon-link text-neutral-400 transition-colors duration-200 hover:text-primary dark:text-neutral-500 dark:hover:text-primary-light"
							title={social.name}
						>
							<span class="sr-only">{social.name}</span>
							<div class="footer-social-icon">
								<Fragment set:html={social.icon} />
							</div>
						</a>
					))}
				</span>
			</div>
		</div>
	</div>
</section>

<ToTop />

<style is:global>
	.footer-social-icon {
		width: 20px;
		height: 20px;
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
	}

	.footer-social-icon svg {
		width: 18px;
		height: 18px;
		fill: currentColor;
	}

	.footer-social-icon-link:hover .ic-twitter {
		color: #1da1f2;
	}

	.footer-social-icon-link:hover .ic-github {
		color: #333;
	}

	.footer-social-icon-link:hover .ic-rss {
		color: #f26522;
	}
</style>
