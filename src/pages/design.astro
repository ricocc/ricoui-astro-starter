---
import Layout from "@/layouts/Layout.astro";
import PageHeader from "@/components/elements/PageHeader.astro";
import Button from "@/components/ui/Button.astro";
import Badge from "@/components/ui/Badge.astro";
import { themes } from "@/config/themes";
import { ArrowRight, FileText, Route, Type } from "@lucide/astro";

const sourceFiles = [
	"src/config/themes.js",
	"src/styles/global.css",
	"src/styles/themes.css",
	"src/layouts/Layout.astro",
	"src/components/sections/Header.astro",
	"docs/DESIGN.md",
	"docs/DESIGN/{theme-id}.md",
];

const tokenRows = [
	{ token: "--color-primary", usage: "品牌色、链接、CTA、标题" },
	{ token: "--color-primary-strong", usage: "悬停和强调" },
	{ token: "--color-primary-light", usage: "柔和点缀和聚焦表面" },
	{ token: "--color-accent", usage: "徽章和次要高亮" },
	{ token: "--color-bg-primary", usage: "浅色页面画布" },
	{ token: "--color-bg-secondary", usage: "卡片和面板" },
	{ token: "--color-text-primary", usage: "标题和强调文字" },
	{ token: "--color-text-secondary", usage: "正文文字" },
	{ token: "--color-text-tertiary", usage: "弱化元数据" },
	{ token: "--color-btn-primary", usage: "填充按钮背景" },
	{ token: "--color-btn-primary-hover", usage: "填充按钮悬停背景" },
	{ token: "--color-btn-primary-text", usage: "填充按钮前景" },
];

const typeTokens = [
	{ token: "--font-brand", value: "Noto Sans SC", usage: "展示标题和大号章节标题" },
	{ token: "--font-sans", value: "Inter", usage: "正文、导航、按钮、UI 标签" },
	{ token: "--font-body", value: "Inter", usage: "长篇内容" },
];

const rules = [
	"主题切换仅更改语义化颜色令牌。",
	"排版、间距、圆角、布局和组件结构保持稳定。",
	"使用 src/config/themes.js 作为主题选项的真实来源。",
	"使用 localStorage.theme_id、theme_id cookie 回退和 html[data-theme] 进行运行时选择。",
	"为每个主题保持亮色和暗色模式样式配对。",
	"每个主题保留一个 DESIGN.md 文件，文件内包含独立的亮色和暗色令牌部分。",
	"将每个主题视为一个颜色系统，而不是完整的组件替换。",
];

const patterns = [
	{ title: "营销板块", desc: "使用 .site-container、SectionHeader、响应式网格和虚线分隔符。" },
	{ title: "文章页面", desc: "使用 PostLayout、文章样式、目录、阅读进度和 MDX 内容条目。" },
	{ title: "主题参考", desc: "使用 /elements 检查活动主题如何影响实际组件。" },
];

const styleFromTokens = (tokens: Record<string, string>) => {
	const previewTokens = {
		...tokens,
		"--color-btn-primary": tokens["--color-btn-primary"] ?? tokens["--color-primary"],
		"--color-btn-primary-hover": tokens["--color-btn-primary-hover"] ?? tokens["--color-primary-strong"],
		"--color-btn-primary-text": tokens["--color-btn-primary-text"] ?? "#ffffff",
		"--color-primary-bg": tokens["--color-bg-primary"],
		"--color-primary-bg-light": tokens["--color-bg-secondary"],
	};

	return Object.entries(previewTokens)
		.map(([key, value]) => `${key}:${value}`)
		.join(";");
};
---

<Layout
	title="设计文档 - RicoUI Astro 启动模板"
	description="RicoUI Astro 启动模板主题系统的网页预览，包含令牌映射、源文件、UI 规则和组件指南。"
>
	<section class="site-container my-12">
		<PageHeader
			title="设计文档"
			description="启动模板的设计系统、主题颜色和实现规则。"
		/>
	</section>

	<section class="site-container py-8 md:py-12">
		<div class="grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
			<div class="rounded-xl border border-primary/10 bg-bg-secondary p-6 dark:border-neutral-700 dark:bg-bg-secondary-dark">
				<div class="mb-4 inline-flex items-center gap-2 rounded-md bg-primary/10 px-3 py-1 text-xs font-medium text-primary dark:bg-primary/20 dark:text-primary-light">
					<FileText class="h-3.5 w-3.5" /> 主题系统
				</div>
				<h2 class="mb-4 text-3xl font-brand text-neutral-800 dark:text-neutral-100">
					选择配色方向，无需更改整个系统
				</h2>
				<p class="leading-relaxed text-neutral-600 dark:text-neutral-300">
					RicoUI 现在附带颜色主题包。它们切换语义化颜色令牌，同时保留模板的排版、间距、布局、圆角和组件行为。
				</p>
				<div class="mt-6 flex flex-wrap gap-3">
					<Button url="/elements" type="fill">
						查看组件库 <ArrowRight size={16} />
					</Button>
					<Button url="https://github.com/ricocc/ricoui-astro-starter/tree/master/docs/DESIGN" target="_blank">
						查看原始文件
					</Button>
				</div>
			</div>

			<div class="rounded-xl border border-dashed border-primary/20 bg-bg-secondary p-6 dark:border-neutral-700 dark:bg-bg-secondary-dark">
				<h3 class="mb-4 flex items-center gap-2 text-lg font-semibold text-neutral-800 dark:text-neutral-100">
					<Route class="h-4 w-4 text-primary" /> 源文件
				</h3>
				<div class="grid gap-2">
					{sourceFiles.map((file) => (
						<div class="rounded-lg bg-bg-primary px-3 py-2 font-mono text-xs text-neutral-600 dark:bg-neutral-800/60 dark:text-neutral-300">
							{file}
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<section class="site-container py-16 md:py-20">
		<div class="mb-8 flex flex-wrap items-end justify-between gap-4">
			<div>
				<Badge variant="accent">详情</Badge>
				<h2 class="mt-3 text-3xl font-brand text-neutral-800 dark:text-neutral-100">主题详情</h2>
			</div>
			<p class="max-w-xl text-sm leading-relaxed text-neutral-500 dark:text-neutral-400">
				每个主题都保持了启动模板的结构完整。展开主题可查看来源氛围、颜色角色和实现指南。
			</p>
		</div>

		<div class="grid gap-4">
			{themes.map((theme) => (
				<details
					class="group overflow-hidden rounded-xl border border-primary/10 bg-bg-secondary dark:border-neutral-700 dark:bg-bg-secondary-dark"
					style={styleFromTokens(theme.tokens.light)}
				>
					<summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 transition-colors hover:bg-primary/5 [&::-webkit-details-marker]:hidden">
						<span class="min-w-0">
							<span class="mb-1 flex flex-wrap items-center gap-2">
								<span class="flex h-6 w-12 overflow-hidden rounded-md border border-white/70 shadow-sm">
									{theme.swatches.slice(0, 4).map((color) => (
										<span class="h-full flex-1" style={`background:${color}`}></span>
									))}
								</span>
								<span class="text-lg font-semibold text-text-primary">{theme.name}</span>
							</span>
							<span class="block text-xs leading-relaxed text-text-tertiary">{theme.source}</span>
						</span>
						<span class="flex-none rounded-full border border-primary/15 px-3 py-1 text-xs font-medium text-text-secondary transition-colors group-open:bg-btn-primary group-open:text-btn-primary-text">
							详情
						</span>
					</summary>
					<div class="border-t border-primary/10 px-5 py-5">
						<p class="max-w-3xl text-sm leading-relaxed text-text-secondary">{theme.details.atmosphere}</p>
						<div class="mt-5 grid gap-4 lg:grid-cols-3">
							<div class="rounded-lg bg-bg-primary p-4">
								<p class="mb-3 text-xs font-medium uppercase tracking-[0.14em] text-text-tertiary">适用场景</p>
								<div class="flex flex-wrap gap-2">
									{theme.details.bestFor.map((item) => (
										<span class="rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-text-primary">{item}</span>
									))}
								</div>
							</div>
							<div class="rounded-lg bg-bg-primary p-4 lg:col-span-2">
								<p class="mb-3 text-xs font-medium uppercase tracking-[0.14em] text-text-tertiary">颜色角色</p>
								<div class="grid gap-3 md:grid-cols-3">
									{theme.details.colorRoles.map((role) => (
										<div>
											<div class="mb-2 flex items-center gap-2">
												<span class="h-5 w-5 rounded-md border border-white/70 shadow-sm" style={`background:${role.value}`}></span>
												<span class="text-sm font-semibold text-text-primary">{role.name}</span>
											</div>
											<p class="font-mono text-[11px] text-text-tertiary">{role.value}</p>
											<p class="mt-1 text-xs leading-relaxed text-text-secondary">{role.role}</p>
										</div>
									))}
								</div>
							</div>
						</div>
						<div class="mt-4 rounded-lg border border-primary/10 bg-bg-primary p-4">
							<div class="mb-3 flex flex-wrap items-center justify-between gap-3">
								<p class="text-xs font-medium uppercase tracking-[0.14em] text-text-tertiary">指南</p>
								<span class="font-mono text-[11px] text-text-tertiary">{theme.designDoc}</span>
							</div>
							<ul class="grid gap-2 text-sm leading-relaxed text-text-secondary md:grid-cols-3">
								{theme.details.guidance.map((item) => (
									<li>{item}</li>
								))}
							</ul>
						</div>
					</div>
				</details>
			))}
		</div>
	</section>

	<section class="site-container py-16 md:py-20">
		<div class="mb-8 flex flex-wrap items-end justify-between gap-4">
			<div>
				<Badge variant="primary">主题</Badge>
				<h2 class="mt-3 text-3xl font-brand text-neutral-800 dark:text-neutral-100">主题画廊</h2>
			</div>
			<p class="max-w-xl text-sm leading-relaxed text-neutral-500 dark:text-neutral-400">
				使用顶栏主题切换器在全站预览这些主题。下方每张卡片都渲染自相同的主题配置。
			</p>
		</div>

		<div class="-mx-4 overflow-x-auto px-4 pb-4">
			<div class="grid auto-cols-[minmax(280px,340px)] grid-flow-col gap-5">
			{themes.map((theme) => (
				<article
					class="overflow-hidden rounded-xl border border-primary/10 bg-bg-secondary dark:border-neutral-700 dark:bg-bg-secondary-dark"
					style={styleFromTokens(theme.tokens.light)}
				>
					<div class="flex h-20">
						{theme.swatches.map((color) => (
							<div class="flex-1" style={`background:${color}`}></div>
						))}
					</div>
					<div class="p-5">
						<p class="mb-1 text-xs font-medium uppercase tracking-[0.14em] text-neutral-400">{theme.source}</p>
						<h3 class="mb-2 text-2xl font-brand text-text-primary">{theme.name}</h3>
						<p class="mb-5 text-sm leading-relaxed text-text-secondary">{theme.description}</p>
						<div class="mb-4 grid gap-2">
							<div>
								<p class="mb-1 text-[10px] font-medium uppercase tracking-[0.14em] text-neutral-400">亮色</p>
								<div class="flex h-7 overflow-hidden rounded-md border border-white/70 shadow-sm">
									{theme.lightSwatches.map((color) => (
										<span class="flex-1" style={`background:${color}`}></span>
									))}
								</div>
							</div>
							<div>
								<p class="mb-1 text-[10px] font-medium uppercase tracking-[0.14em] text-neutral-400">暗色</p>
								<div class="flex h-7 overflow-hidden rounded-md border border-white/20 shadow-sm">
									{theme.darkSwatches.map((color) => (
										<span class="flex-1" style={`background:${color}`}></span>
									))}
								</div>
							</div>
						</div>
						<div class="rounded-lg border border-primary/15 bg-bg-primary p-4">
							<p class="mb-2 text-lg font-brand text-text-primary">标题示例</p>
							<p class="mb-4 text-sm leading-relaxed text-text-secondary">
								正文字体保持相同的节奏，而调色板在周围变化。
							</p>
							<div class="flex flex-wrap items-center gap-2">
								<span class="inline-flex rounded-lg bg-btn-primary px-3 py-2 text-xs font-medium text-btn-primary-text">
									主要操作
								</span>
								<span class="font-mono text-[11px] text-text-tertiary">{theme.designDoc}</span>
							</div>
						</div>
					</div>
				</article>
			))}
			</div>
		</div>
	</section>

	<section class="site-container py-16 md:py-20">
		<div class="mb-8 flex flex-wrap items-end justify-between gap-4">
			<div>
				<Badge variant="primary">令牌</Badge>
				<h2 class="mt-3 text-3xl font-brand text-neutral-800 dark:text-neutral-100">语义化颜色映射</h2>
			</div>
			<p class="max-w-xl text-sm leading-relaxed text-neutral-500 dark:text-neutral-400">
				以下是添加新颜色主题时开发者应调整的值。
			</p>
		</div>

		<div class="overflow-x-auto rounded-xl border border-primary/10 bg-bg-secondary dark:border-neutral-700 dark:bg-bg-secondary-dark">
			<div style={`min-width: ${260 + themes.length * 190}px;`}>
				<div
					class="grid gap-3 border-b border-dashed border-primary/10 px-4 py-3 text-xs font-medium uppercase tracking-[0.14em] text-neutral-400 dark:border-neutral-700"
					style={`grid-template-columns: minmax(240px,1.1fr) repeat(${themes.length}, minmax(170px,1fr));`}
				>
					<span>令牌</span>
					{themes.map((theme) => <span>{theme.name}</span>)}
				</div>
				{tokenRows.map((row) => (
					<div
						class="grid gap-3 border-b border-primary/5 px-4 py-3 last:border-0 dark:border-neutral-700/50"
						style={`grid-template-columns: minmax(240px,1.1fr) repeat(${themes.length}, minmax(170px,1fr));`}
					>
						<div>
							<p class="font-mono text-xs text-primary">{row.token}</p>
							<p class="mt-1 text-xs text-neutral-500 dark:text-neutral-400">{row.usage}</p>
						</div>
						{themes.map((theme) => (
							<div class="flex items-center gap-2">
								<span
									class="h-7 w-7 rounded-md border border-white/70 shadow-sm dark:border-white/10"
									style={`background:${theme.tokens.light[row.token]}`}
								></span>
								<span class="font-mono text-xs text-neutral-500 dark:text-neutral-400">{theme.tokens.light[row.token]}</span>
							</div>
						))}
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="site-container py-16 md:py-20">
		<div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr]">
			<div>
				<Badge variant="accent">排版</Badge>
				<h2 class="mt-3 text-3xl font-brand text-neutral-800 dark:text-neutral-100">字体保持一致</h2>
				<p class="mt-4 leading-relaxed text-neutral-600 dark:text-neutral-300">
					主题切换器刻意仅用于颜色。字体和间距保持稳定，开发者可以比较调色板而无需重建界面。
				</p>
			</div>
			<div class="grid gap-3">
				{typeTokens.map((item) => (
					<div
						class="rounded-xl border border-primary/10 bg-bg-secondary p-5 dark:border-neutral-700 dark:bg-bg-secondary-dark"
					>
						<div class="mb-2 flex items-center gap-2">
							<Type class="h-4 w-4 text-primary" />
							<span class="font-mono text-xs text-primary">{item.token}</span>
						</div>
						<p class:list={["text-2xl text-neutral-800 dark:text-neutral-100", item.token === "--font-brand" ? "font-brand" : "font-sans"]}>
							{item.value}
						</p>
						<p class="mt-2 text-sm text-neutral-500 dark:text-neutral-400">{item.usage}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="site-container py-16 md:py-20">
		<div class="grid gap-8 lg:grid-cols-2">
			<div>
				<h2 class="mb-4 text-3xl font-brand text-neutral-800 dark:text-neutral-100">主题规则</h2>
				<div class="grid gap-3">
					{rules.map((rule) => (
						<div
							class="rounded-lg border border-dashed border-primary/20 bg-bg-secondary px-4 py-3 text-sm text-neutral-600 dark:border-neutral-700 dark:bg-bg-secondary-dark dark:text-neutral-300"
						>
							{rule}
						</div>
					))}
				</div>
			</div>
			<div>
				<h2 class="mb-4 text-3xl font-brand text-neutral-800 dark:text-neutral-100">页面模式</h2>
				<div class="grid gap-4">
					{patterns.map((pattern) => (
						<article
							class="rounded-xl border border-primary/10 bg-bg-secondary p-5 dark:border-neutral-700 dark:bg-bg-secondary-dark"
						>
							<h3 class="mb-2 text-lg font-semibold text-neutral-800 dark:text-neutral-100">{pattern.title}</h3>
							<p class="text-sm leading-relaxed text-neutral-500 dark:text-neutral-400">{pattern.desc}</p>
						</article>
					))}
				</div>
			</div>
		</div>
	</section>
</Layout>
