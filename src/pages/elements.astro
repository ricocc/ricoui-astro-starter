---
import Layout from "@/layouts/Layout.astro";
import PageHeader from "@/components/elements/PageHeader.astro";
import Button from "@/components/ui/Button.astro";
import Badge from "@/components/ui/Badge.astro";
import AccordionItem from "@/components/ui/AccordionItem.astro";
import SectionHeader from "@/components/elements/SectionHeader.astro";
import { themes } from "@/config/themes";
import {
  ArrowRight, Mail, Check, X, Zap, Sparkles, Palette, Code, Globe, Shield,
  Rocket, Bot, ChartNoAxesColumn, PenTool, Monitor, Smartphone, GitFork, Layers,
  FileText, LayoutDashboard, Copy, Wrench, Menu, ChevronRight, ChevronLeft,
  ChevronDown, ExternalLink, Sun, Moon, Search, Download, Grid3x3, List,
  Rss, Lock, CircleAlert, CircleCheck, Info, TriangleAlert
} from "@lucide/astro";

const colorPalette = [
  { name: "主色", value: "var(--color-primary)", token: "--color-primary" },
  { name: "主色强调", value: "var(--color-primary-strong)", token: "--color-primary-strong" },
  { name: "主色浅色", value: "var(--color-primary-light)", token: "--color-primary-light" },
  { name: "强调色", value: "var(--color-accent)", token: "--color-accent" },
];

const neutralScale = [
  { name: "50", value: "#f7f9fc" },
  { name: "100", value: "#edf1f8" },
  { name: "200", value: "#dfe4ed" },
  { name: "300", value: "#c5cedb" },
  { name: "400", value: "#92a1b7" },
  { name: "500", value: "#677487" },
  { name: "600", value: "#4f5a6d" },
  { name: "700", value: "#3f4a5a" },
  { name: "800", value: "#2c3542" },
  { name: "900", value: "#19222f" },
  { name: "950", value: "#10161f" },
];

const bgColors = [
  { name: "背景主色", value: "var(--color-bg-primary)", token: "--color-bg-primary" },
  { name: "背景次色", value: "var(--color-bg-secondary)", token: "--color-bg-secondary" },
  { name: "背景浅色", value: "var(--color-bg-primary-light)", token: "--color-bg-primary-light" },
  { name: "暗色背景", value: "var(--color-bg-primary-dark)", token: "--color-bg-primary-dark" },
  { name: "暗色次背景", value: "var(--color-bg-secondary-dark)", token: "--color-bg-secondary-dark" },
];

const textColors = [
  { name: "主文字", value: "var(--color-text-primary)", token: "--color-text-primary" },
  { name: "次文字", value: "var(--color-text-secondary)", token: "--color-text-secondary" },
  { name: "辅助文字", value: "var(--color-text-tertiary)", token: "--color-text-tertiary" },
];

const icons = [
  { Icon: Menu, name: "Menu", usage: "移动端导航" },
  { Icon: X, name: "X", usage: "关闭" },
  { Icon: ChevronRight, name: "ChevronRight", usage: "面包屑" },
  { Icon: ChevronLeft, name: "ChevronLeft", usage: "分页" },
  { Icon: ChevronDown, name: "ChevronDown", usage: "下拉菜单" },
  { Icon: ArrowRight, name: "ArrowRight", usage: "CTA 按钮" },
  { Icon: ExternalLink, name: "ExternalLink", usage: "外部链接" },
  { Icon: Sun, name: "Sun", usage: "浅色模式" },
  { Icon: Moon, name: "Moon", usage: "暗色模式" },
  { Icon: Mail, name: "Mail", usage: "联系方式" },
  { Icon: Search, name: "Search", usage: "搜索" },
  { Icon: Download, name: "Download", usage: "下载" },
  { Icon: Copy, name: "Copy", usage: "复制文本" },
  { Icon: Check, name: "Check", usage: "确认" },
  { Icon: FileText, name: "FileText", usage: "博客/文档" },
  { Icon: LayoutDashboard, name: "Layout", usage: "页面布局" },
  { Icon: Layers, name: "Layers", usage: "板块" },
  { Icon: Grid3x3, name: "Grid", usage: "网格视图" },
  { Icon: List, name: "List", usage: "列表视图" },
  { Icon: GitFork, name: "GitFork", usage: "GitHub 链接" },
  { Icon: Rss, name: "Rss", usage: "RSS 订阅" },
  { Icon: Zap, name: "Zap", usage: "性能" },
  { Icon: Sparkles, name: "Sparkles", usage: "动画效果" },
  { Icon: Palette, name: "Palette", usage: "自定义" },
  { Icon: Code, name: "Code", usage: "开发" },
  { Icon: Globe, name: "Globe", usage: "网站" },
  { Icon: Shield, name: "Shield", usage: "安全" },
  { Icon: Lock, name: "Lock", usage: "认证" },
  { Icon: Rocket, name: "Rocket", usage: "启动" },
  { Icon: Bot, name: "Bot", usage: "AI 工具" },
  { Icon: ChartNoAxesColumn, name: "BarChart", usage: "数据分析" },
  { Icon: PenTool, name: "PenTool", usage: "设计" },
  { Icon: Monitor, name: "Monitor", usage: "桌面端" },
  { Icon: Smartphone, name: "Smartphone", usage: "移动端" },
  { Icon: CircleAlert, name: "AlertCircle", usage: "错误状态" },
  { Icon: CircleCheck, name: "CheckCircle", usage: "成功" },
  { Icon: Info, name: "Info", usage: "信息" },
  { Icon: TriangleAlert, name: "AlertTriangle", usage: "警告" },
  { Icon: Wrench, name: "Wrench", usage: "设置" },
];

const sampleFaq = [
  { question: "示例手风琴问题？", answer: "这是用于演示 AccordionItem 组件的示例答案。它支持富 HTML 内容。" },
  { question: "可以自定义吗？", answer: "是的，所有组件都接受 props 以便轻松自定义。查看源代码了解可用选项。" },
];
---

<Layout
  title="组件库 - RicoUI Astro 启动模板"
  description="RicoUI Astro 启动模板的组件库和设计系统参考。"
>
  <section class="site-container my-12">
    <PageHeader
      title="组件库"
      description="组件库和网站主题参考。"
    />
  </section>

  <section class="site-container py-8 md:py-12">
    <div class="grid gap-5 lg:grid-cols-[0.85fr_1.15fr]">
      <div class="rounded-xl border border-primary/10 bg-bg-secondary p-6 dark:border-neutral-700 dark:bg-bg-secondary-dark">
        <Badge variant="primary">主题感知</Badge>
        <h2 class="mt-4 text-3xl font-brand text-neutral-800 dark:text-neutral-100">组件跟随顶栏活动主题</h2>
        <p class="mt-3 text-sm leading-relaxed text-neutral-500 dark:text-neutral-400">
          在顶栏中切换内置颜色主题。本页面使用语义化 CSS 变量，因此控件和表面会在不更改组件结构的情况下更新。
        </p>
      </div>
      <div class="-mx-2 overflow-x-auto px-2 pb-3">
        <div class="grid auto-cols-[minmax(220px,280px)] grid-flow-col gap-3">
          {themes.map((theme) => (
            <article class="rounded-xl border border-primary/10 bg-bg-secondary p-4 dark:border-neutral-700 dark:bg-bg-secondary-dark">
              <div class="mb-4 flex h-10 overflow-hidden rounded-lg border border-white/70 shadow-sm dark:border-white/10">
                {theme.swatches.map((color) => (
                  <span class="flex-1" style={`background:${color}`}></span>
                ))}
              </div>
              <h3 class="text-lg font-brand text-neutral-800 dark:text-neutral-100">{theme.name}</h3>
              <p class="mt-1 text-xs leading-relaxed text-neutral-500 dark:text-neutral-400">{theme.source}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- 1. 颜色 -->
  <section class="site-container py-16 md:py-24">
    <h2 class="text-3xl font-brand text-neutral-800 dark:text-neutral-100 mb-2">颜色</h2>
    <p class="text-sm text-neutral-500 dark:text-neutral-400 mb-10">活动主题调色板、中性色阶、背景色和文字颜色。</p>

    <div class="space-y-10">
      <div>
        <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-4">主色调色板</h3>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          {colorPalette.map((c) => (
            <div class="rounded-xl overflow-hidden border border-neutral-200 dark:border-neutral-700">
              <div class="h-20" style={`background-color: ${c.value}`}></div>
              <div class="p-3">
                <p class="text-xs font-semibold text-neutral-800 dark:text-neutral-100">{c.name}</p>
                <p class="text-xs text-neutral-400 font-mono mt-0.5" data-token-value={c.token}>当前值</p>
                <p class="text-xs text-neutral-400 font-mono">{c.token}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div>
        <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-4">中性色阶</h3>
        <div class="grid grid-cols-3 sm:grid-cols-6 lg:grid-cols-11 gap-2">
          {neutralScale.map((c) => (
            <div class="text-center">
              <div class="h-14 rounded-lg border border-neutral-200 dark:border-neutral-700" style={`background-color: ${c.value}`}></div>
              <p class="text-[10px] text-neutral-500 mt-1">{c.name}</p>
              <p class="text-[10px] text-neutral-400 font-mono">{c.value}</p>
            </div>
          ))}
        </div>
      </div>

      <div>
        <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-4">背景颜色</h3>
        <div class="grid grid-cols-2 sm:grid-cols-5 gap-4">
          {bgColors.map((c) => (
            <div class="text-center">
              <div class="h-16 rounded-lg border border-neutral-200 dark:border-neutral-700" style={`background-color: ${c.value}`}></div>
              <p class="text-xs text-neutral-500 mt-2">{c.name}</p>
              <p class="text-[10px] text-neutral-400 font-mono" data-token-value={c.token}>{c.token}</p>
            </div>
          ))}
        </div>
      </div>

      <div>
        <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-4">文字颜色</h3>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {textColors.map((c) => (
            <div class="p-4 rounded-xl border border-neutral-200 dark:border-neutral-700">
              <div class="w-8 h-8 rounded-lg mb-2" style={`background-color: ${c.value}`}></div>
              <p class="text-sm font-medium" style={`color: ${c.value}`}>{c.name}</p>
              <p class="text-xs text-neutral-400 font-mono" data-token-value={c.token}>当前值</p>
              <p class="text-xs text-neutral-400 font-mono">{c.token}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <div class="w-full border-b border-dashed border-neutral-200 dark:border-neutral-700 my-4 site-container"></div>

  <!-- 2. 排版 -->
  <section class="site-container py-16 md:py-24">
    <h2 class="text-3xl font-brand text-neutral-800 dark:text-neutral-100 mb-2">排版</h2>
    <p class="text-sm text-neutral-500 dark:text-neutral-400 mb-10">字体族、字号比例和字重变体。</p>

    <div class="space-y-10">
      <div>
        <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-4">字体族</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="p-6 rounded-xl border border-neutral-200 dark:border-neutral-700">
            <p class="text-xs text-neutral-400 mb-2 font-mono">--font-brand (Noto Sans SC)</p>
            <p class="text-3xl font-brand text-neutral-800 dark:text-neutral-100">品牌字体</p>
          </div>
          <div class="p-6 rounded-xl border border-neutral-200 dark:border-neutral-700">
            <p class="text-xs text-neutral-400 mb-2 font-mono">--font-sans (Noto Sans SC)</p>
            <p class="text-3xl font-sans text-neutral-800 dark:text-neutral-100">正文</p>
          </div>
        </div>
      </div>

      <div>
        <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-4">字号比例</h3>
        <div class="space-y-4">
          <div class="p-4 rounded-xl border border-neutral-200 dark:border-neutral-700">
            <p class="text-xs text-neutral-400 mb-1">Display — 48px / 400</p>
            <p class="text-5xl font-brand text-neutral-800 dark:text-neutral-100">标题</p>
          </div>
          <div class="p-4 rounded-xl border border-neutral-200 dark:border-neutral-700">
            <p class="text-xs text-neutral-400 mb-1">Heading 1 — 36px / 400</p>
            <p class="text-4xl font-brand text-neutral-800 dark:text-neutral-100">主标题</p>
          </div>
          <div class="p-4 rounded-xl border border-neutral-200 dark:border-neutral-700">
            <p class="text-xs text-neutral-400 mb-1">Heading 2 — 28px / 400</p>
            <p class="text-3xl font-brand text-neutral-800 dark:text-neutral-100">章节标题</p>
          </div>
          <div class="p-4 rounded-xl border border-neutral-200 dark:border-neutral-700">
            <p class="text-xs text-neutral-400 mb-1">Heading 3 — 20px / 600</p>
            <p class="text-xl font-semibold text-neutral-800 dark:text-neutral-100">小节标题</p>
          </div>
          <div class="p-4 rounded-xl border border-neutral-200 dark:border-neutral-700">
            <p class="text-xs text-neutral-400 mb-1">Body — 16px / 400</p>
            <p class="text-base text-neutral-600 dark:text-neutral-300 leading-relaxed">天地玄黄，宇宙洪荒。日月盈昃，辰宿列张。一个简洁、快速、可复用的 Astro 启动模板，使用 Tailwind CSS 构建。</p>
          </div>
          <div class="p-4 rounded-xl border border-neutral-200 dark:border-neutral-700">
            <p class="text-xs text-neutral-400 mb-1">Body Small — 14px / 400</p>
            <p class="text-sm text-neutral-500 dark:text-neutral-400">用于描述和次要内容的辅助文字。</p>
          </div>
          <div class="p-4 rounded-xl border border-neutral-200 dark:border-neutral-700">
            <p class="text-xs text-neutral-400 mb-1">Caption — 12px / 400</p>
            <p class="text-xs text-neutral-400">时间戳、元数据和附加说明。</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="w-full border-b border-dashed border-neutral-200 dark:border-neutral-700 my-4 site-container"></div>

  <!-- 3. 按钮 -->
  <section class="site-container py-16 md:py-24">
    <h2 class="text-3xl font-brand text-neutral-800 dark:text-neutral-100 mb-2">按钮</h2>
    <p class="text-sm text-neutral-500 dark:text-neutral-400 mb-10">主要、次要、描边和禁用变体，多种尺寸。</p>

    <div class="space-y-8">
      <div>
        <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-4">变体</h3>
        <div class="flex flex-wrap items-center gap-4">
          <Button url="#" type="fill">主要填充</Button>
          <Button url="#" type="solid">次要实心</Button>
          <Button url="#" type="outline">描边</Button>
          <Button url="#" type="disabled">禁用</Button>
        </div>
      </div>

      <div>
        <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-4">尺寸</h3>
        <div class="flex flex-wrap items-center gap-4">
          <Button url="#" type="fill" size="xs">超小</Button>
          <Button url="#" type="fill" size="sm">小</Button>
          <Button url="#" type="fill" size="md">中</Button>
          <Button url="#" type="fill" size="lg">大</Button>
          <Button url="#" type="fill" size="xl">超大</Button>
        </div>
      </div>

      <div>
        <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-4">带图标</h3>
        <div class="flex flex-wrap items-center gap-4">
          <Button url="#" type="fill">开始使用 <ArrowRight size={16} /></Button>
          <Button url="#" type="outline"><Mail size={16} /> 发送邮件</Button>
          <Button url="#" type="fill"><GitFork size={16} /> 在 GitHub 上星标</Button>
        </div>
      </div>
    </div>
  </section>

  <div class="w-full border-b border-dashed border-neutral-200 dark:border-neutral-700 my-4 site-container"></div>

  <!-- 4. 徽章 -->
  <section class="site-container py-16 md:py-24">
    <h2 class="text-3xl font-brand text-neutral-800 dark:text-neutral-100 mb-2">徽章和标签</h2>
    <p class="text-sm text-neutral-500 dark:text-neutral-400 mb-10">多种变体和尺寸的状态标签。</p>

    <div class="space-y-8">
      <div>
        <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-4">变体</h3>
        <div class="flex flex-wrap items-center gap-3">
          <Badge variant="primary">主要</Badge>
          <Badge variant="accent">强调</Badge>
          <Badge variant="neutral">中性</Badge>
          <Badge variant="success">成功</Badge>
          <Badge variant="warning">警告</Badge>
          <Badge variant="error">错误</Badge>
        </div>
      </div>

      <div>
        <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-4">尺寸</h3>
        <div class="flex flex-wrap items-center gap-3">
          <Badge variant="primary" size="sm">小</Badge>
          <Badge variant="primary" size="default">默认</Badge>
          <Badge variant="primary" size="lg">大</Badge>
        </div>
      </div>
    </div>
  </section>

  <div class="w-full border-b border-dashed border-neutral-200 dark:border-neutral-700 my-4 site-container"></div>

  <!-- 5. 卡片 -->
  <section class="site-container py-16 md:py-24">
    <h2 class="text-3xl font-brand text-neutral-800 dark:text-neutral-100 mb-2">卡片</h2>
    <p class="text-sm text-neutral-500 dark:text-neutral-400 mb-10">基础卡片、功能卡片和内容卡片样式。</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="p-6 rounded-xl bg-bg-secondary dark:bg-bg-secondary-dark border border-primary/10 dark:border-neutral-700">
        <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-2">基础卡片</h3>
        <p class="text-sm text-neutral-500 dark:text-neutral-400">带有边框、背景和内边距的简单卡片。</p>
      </div>

      <div class="p-6 rounded-xl bg-bg-secondary dark:bg-bg-secondary-dark border border-primary/10 dark:border-neutral-700 hover:shadow-md hover:-translate-y-1 transition-all duration-300">
        <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center mb-4">
          <Zap class="w-5 h-5 text-primary" />
        </div>
        <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-2">功能卡片</h3>
        <p class="text-sm text-neutral-500 dark:text-neutral-400">带图标、悬停升起效果和阴影。</p>
      </div>

      <div class="rounded-xl bg-bg-secondary dark:bg-bg-secondary-dark border border-primary/10 dark:border-neutral-700 overflow-hidden">
        <div class="h-32 bg-gradient-to-br from-primary/20 to-primary/5 flex items-center justify-center">
          <Sparkles class="w-8 h-8 text-primary/50" />
        </div>
        <div class="p-6">
          <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-2">内容卡片</h3>
          <p class="text-sm text-neutral-500 dark:text-neutral-400">带图片占位符，类似博客卡片。</p>
        </div>
      </div>
    </div>
  </section>

  <div class="w-full border-b border-dashed border-neutral-200 dark:border-neutral-700 my-4 site-container"></div>

  <!-- 6. 表单元素 -->
  <section class="site-container py-16 md:py-24 max-w-2xl mx-auto">
    <h2 class="text-3xl font-brand text-neutral-800 dark:text-neutral-100 mb-2">表单元素</h2>
    <p class="text-sm text-neutral-500 dark:text-neutral-400 mb-10">输入框、选择框、文本域和开关。</p>

    <div class="space-y-6">
      <div>
        <label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-2">文本输入</label>
        <input type="text" placeholder="请输入您的姓名" class="w-full px-4 py-3 rounded-lg border border-neutral-200 dark:border-neutral-700 bg-bg-secondary dark:bg-bg-secondary-dark text-neutral-800 dark:text-neutral-100 placeholder-neutral-400 dark:placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-2">邮箱输入</label>
        <input type="email" placeholder="your@email.com" class="w-full px-4 py-3 rounded-lg border border-neutral-200 dark:border-neutral-700 bg-bg-secondary dark:bg-bg-secondary-dark text-neutral-800 dark:text-neutral-100 placeholder-neutral-400 dark:placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors" />
      </div>
      <div>
        <label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-2">选择框</label>
        <select class="w-full px-4 py-3 rounded-lg border border-neutral-200 dark:border-neutral-700 bg-bg-secondary dark:bg-bg-secondary-dark text-neutral-800 dark:text-neutral-100 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors">
          <option>选项 A</option>
          <option>选项 B</option>
          <option>选项 C</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-2">文本域</label>
        <textarea rows="3" placeholder="请输入您的留言..." class="w-full px-4 py-3 rounded-lg border border-neutral-200 dark:border-neutral-700 bg-bg-secondary dark:bg-bg-secondary-dark text-neutral-800 dark:text-neutral-100 placeholder-neutral-400 dark:placeholder-neutral-500 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors resize-none"></textarea>
      </div>
      <div>
        <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-4">开关</h3>
        <label class="inline-flex items-center gap-3 cursor-pointer">
          <input type="checkbox" class="peer sr-only" checked />
          <span class="relative h-7 w-12 rounded-full bg-neutral-200 transition-colors peer-checked:bg-primary peer-checked:[&>span]:translate-x-5 dark:bg-neutral-700">
            <span class="absolute left-1 top-1 h-5 w-5 rounded-full bg-white shadow-sm transition-transform"></span>
          </span>
