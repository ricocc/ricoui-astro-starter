</Layout>

<script>
  function syncTokenValues() {
    const styles = getComputedStyle(document.documentElement);
    document.querySelectorAll<HTMLElement>('[data-token-value]').forEach((node) => {
      const token = node.dataset.tokenValue;
      if (!token) return;
      const value = styles.getPropertyValue(token).trim();
      node.textContent = value || token;
    });
  }

  document.addEventListener('DOMContentLoaded', syncTokenValues);
  window.addEventListener('themechange', syncTokenValues);
</script>
