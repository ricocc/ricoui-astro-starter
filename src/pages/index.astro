---
import Layout from "@/layouts/Layout.astro";
import HeroSection from "@/components/home/HeroSection.astro";
import SectionHeader from "@/components/elements/SectionHeader.astro";
import BlogSection from "@/components/sections/BlogSection.astro";
import Button from "@/components/ui/Button.astro";
import BrowserFrame from "@/components/ui/BrowserFrame.astro";
import { siteConfig } from "@/config/site";
import {
	ArrowRight,
	BookOpen,
	Brush,
	FilePenLine,
	FileText,
	FolderOpen,
	Layers,
	LayoutTemplate,
	Palette,
	Rss,
	Settings,
	Sparkles,
} from "@lucide/astro";

const starterScope = [
	{
		icon: Palette,
		title: "主题优先",
		desc: "全局令牌定义了调色板、排版、圆角、表面和暗色模式，在页面开始倍增之前就已就绪。",
	},
	{
		icon: FileText,
		title: "包含设计文档",
		desc: "设计说明是模板的一部分，人类构建者和 AI 智能体可以遵循相同的视觉规则。",
	},
	{
		icon: BookOpen,
		title: "博客就绪",
		desc: "MDX 文章、RSS、分页、文章布局、目录和图片处理已经配置完成。",
	},
	{
		icon: Layers,
		title: "组件主题",
		desc: "按钮、徽章、卡片、排版、动效、表单控件和布局原语集中在一个参考页面中。",
	},
];

const fileMap = [
	{ path: "src/pages/index.astro", note: "首页" },
	{ path: "src/pages/blog", note: "MDX 博客路由" },
	{ path: "src/pages/design.astro", note: "设计文档预览" },
	{ path: "src/pages/elements.astro", note: "主题组件" },
	{ path: "src/styles/global.css", note: "Tailwind v4 令牌" },
	{ path: "src/config/site.js", note: "站点配置" },
];

const workflow = [
	{
		icon: Settings,
		title: "站点配置",
		desc: "编辑 src/config/site.js",
	},
	{
		icon: Palette,
		title: "主题令牌",
		desc: "在 global.css 和 themes.css 中调整颜色",
	},
	{
		icon: FilePenLine,
		title: "内容文章",
		desc: "在 src/content/post 中编写 MDX",
	},
	{
		icon: LayoutTemplate,
		title: "页面组合",
		desc: "从组件库参考页面构建",
	},
];
---

<Layout
	title="RicoUI Astro 启动模板 - 设计驱动的 Astro 模板"
	description="一个简洁的 Astro 启动模板，包含博客、设计文档、组件库、Tailwind CSS v4、MDX 和可复用的设计主题。"
	keywords="astro 模板, 设计系统, tailwind css, mdx 博客, 网站模板"
>
	<HeroSection />

	<section class="site-container py-16 md:py-24">
		<SectionHeader
			title="纯净的启动界面"
			description="模板保留了有用的部分，移除了产品特定的演示页面、定价文案、认证界面和更新日志填充内容。"
		/>
		<div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
			{starterScope.map((item) => (
				<article
					class="rounded-xl border border-primary/10 bg-bg-secondary p-5 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_12px_30px_rgba(var(--color-primary-rgb),0.08)] dark:border-neutral-700 dark:bg-bg-secondary-dark"
				>
					<div class="mb-4 grid h-10 w-10 place-items-center rounded-lg bg-primary/10 text-primary dark:bg-primary/20 dark:text-primary-light">
						<item.icon class="h-5 w-5" />
					</div>
					<h3 class="mb-2 text-lg font-semibold text-neutral-800 dark:text-neutral-100">{item.title}</h3>
					<p class="text-sm leading-relaxed text-neutral-500 dark:text-neutral-400">{item.desc}</p>
				</article>
			))}
		</div>
	</section>

	<div class="site-container my-4 border-b border-dashed border-neutral-200 dark:border-neutral-700"></div>

	<section class="site-container py-16 md:py-24">
		<div class="grid items-start gap-8 lg:grid-cols-[0.95fr_1.05fr]">
			<div>
				<div class="mb-4 inline-flex items-center gap-2 rounded-md border border-dashed border-primary/25 bg-primary/5 px-3 py-1 text-xs font-medium text-primary">
					<Brush class="h-3.5 w-3.5" /> 主题工作流
				</div>
				<h2 class="mb-4 max-w-xl text-3xl font-brand md:text-4xl">从设计出发，再填充产品</h2>
				<p class="max-w-2xl text-neutral-600 leading-relaxed dark:text-neutral-300">
					这个启动模板刻意保持简洁：它提供了一套精致的视觉系统、一个内容层和一个组件参考。你的应用、品牌、产品截图和文案可以在此基础上接管。
				</p>
				<div class="mt-7 flex flex-wrap gap-3">
					<Button url="/design" type="fill">
						查看设计文档 <ArrowRight size={16} />
					</Button>
					<Button url="/elements">
						浏览组件库
					</Button>
				</div>
			</div>

			<BrowserFrame url="starter/theme-map" className="w-full">
				<div class="grid gap-3 p-4 md:p-5">
					{fileMap.map((file) => (
						<div class="grid grid-cols-[1fr_auto] items-center gap-4 rounded-lg border border-primary/10 bg-bg-primary/50 px-4 py-3 dark:border-neutral-700 dark:bg-neutral-800/40">
							<div class="flex min-w-0 items-center gap-3">
								<FolderOpen class="h-4 w-4 flex-none text-primary" />
								<span class="truncate font-mono text-xs text-neutral-700 dark:text-neutral-200">{file.path}</span>
							</div>
							<span class="rounded-md bg-primary/5 px-2 py-1 text-[10px] text-primary dark:bg-primary/10 dark:text-primary-light">
								{file.note}
							</span>
						</div>
					))}
				</div>
			</BrowserFrame>
		</div>
	</section>

	<section class="site-container py-16 md:py-24">
		<SectionHeader
			title="从克隆到自定义站点的捷径"
			description="大多数首次编辑应该发生在四个地方。其余部分不会妨碍你。"
		/>
		<div class="mt-8 grid gap-4 md:grid-cols-4">
			{workflow.map((step, index) => (
				<div
					class="group rounded-xl border border-dashed border-primary/20 bg-bg-secondary p-5 transition-colors duration-200 hover:border-primary/35 hover:bg-primary/5 dark:border-neutral-700 dark:bg-bg-secondary-dark dark:hover:border-primary/40 dark:hover:bg-primary/10"
				>
					<div class="mb-5 flex items-start justify-between gap-4">
						<span class="grid h-10 w-10 flex-none place-items-center rounded-lg bg-primary/10 text-primary transition-colors duration-200 group-hover:bg-primary group-hover:text-btn-primary-text dark:bg-primary/20 dark:text-primary-light">
							<step.icon class="h-5 w-5" />
						</span>
						<span class="font-mono text-xs font-medium text-primary/75 dark:text-primary-light">
							{String(index + 1).padStart(2, "0")}
						</span>
					</div>
					<h3 class="mb-2 text-base font-semibold text-neutral-800 dark:text-neutral-100">{step.title}</h3>
					<p class="font-mono text-xs leading-relaxed text-neutral-500 dark:text-neutral-400">{step.desc}</p>
				</div>
			))}
		</div>
	</section>

	<div class="site-container my-4 border-b border-dashed border-neutral-200 dark:border-neutral-700"></div>

	<section class="py-16 md:py-24">
		<BlogSection
			title="最新文章"
			description="将博客用于文档、版本说明、随笔或产品更新。"
			limit={3}
		/>
	</section>

	<section class="site-container py-12 md:py-20">
		<div
			class="rounded-xl border border-primary/10 bg-bg-secondary p-7 text-center dark:border-neutral-700 dark:bg-bg-secondary-dark md:p-10"
		>
			<div class="mb-4 flex justify-center">
				<div class="grid h-12 w-12 place-items-center rounded-xl bg-accent/30 text-neutral-800 dark:bg-accent/20 dark:text-neutral-100">
					<Sparkles class="h-5 w-5" />
				</div>
			</div>
			<h2 class="mx-auto mb-4 max-w-2xl text-3xl font-brand md:text-4xl">从主题开始，交付你自己的作品</h2>
			<p class="mx-auto mb-7 max-w-2xl text-neutral-600 dark:text-neutral-300">
				克隆这个模板，保留设计语言，用自己的项目结构和内容替换示例文案。
			</p>
			<div class="flex flex-wrap justify-center gap-3">
				<Button url={siteConfig.social.github} type="fill" target="_blank">
					获取模板 <ArrowRight size={16} />
				</Button>
				<Button url="/rss.xml">
					<Rss size={16} /> RSS
				</Button>
			</div>
		</div>
	</section>
</Layout>
