---
import Layout from "@/layouts/Layout.astro";
import HeroSection from "@/components/home/HeroSection.astro";
import SectionHeader from "@/components/elements/SectionHeader.astro";
import BlogSection from "@/components/sections/BlogSection.astro";
import Button from "@/components/ui/Button.astro";
import BrowserFrame from "@/components/ui/BrowserFrame.astro";
import { siteConfig } from "@/config/site";
import {
	ArrowRight,
	BookOpen,
	Brush,
	FileText,
	FolderOpen,
	Layers,
	Palette,
	Rss,
	Sparkles,
} from "@lucide/astro";

const starterScope = [
	{
		icon: Palette,
		title: "Theme first",
		desc: "Global tokens define the palette, typography, radii, surfaces, and dark mode before pages start to multiply.",
	},
	{
		icon: FileText,
		title: "DESIGN.md included",
		desc: "The design notes are part of the template, so human builders and AI agents can follow the same visual rules.",
	},
	{
		icon: BookOpen,
		title: "Blog ready",
		desc: "MDX posts, RSS, pagination, article layout, table of contents, and image handling are already wired.",
	},
	{
		icon: Layers,
		title: "Element theme",
		desc: "Buttons, badges, cards, typography, motion, form controls, and layout primitives live in one reference page.",
	},
];

const fileMap = [
	{ path: "src/pages/index.astro", note: "starter home" },
	{ path: "src/pages/blog", note: "MDX blog routes" },
	{ path: "src/pages/design.astro", note: "DESIGN.md preview" },
	{ path: "src/pages/elements.astro", note: "theme components" },
	{ path: "src/styles/global.css", note: "Tailwind v4 tokens" },
	{ path: "src/config/site.js", note: "site metadata" },
];

const workflow = [
	"Edit site metadata in src/config/site.js",
	"Adjust tokens in src/styles/global.css",
	"Write posts in src/content/post",
	"Compose new pages from the Elements reference",
];
---

<Layout
	title="RicoUI Astro Starter - Design-led Astro template"
	description="A clean Astro starter with Blog, DESIGN.md, Elements, Tailwind CSS v4, MDX, and a reusable design theme."
	keywords="astro starter, design system, tailwind css, mdx blog, website template"
>
	<HeroSection />

	<section class="site-container py-16 md:py-24">
		<SectionHeader
			title="Pure starter surface"
			description="The template keeps the useful parts visible and removes product-specific demo pages, pricing copy, auth screens, and release-note filler from the public site."
		/>
		<div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
			{starterScope.map((item, index) => (
				<article
					class="rounded-xl border border-primary/10 bg-bg-secondary p-5 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_12px_30px_rgba(45,109,195,0.08)] dark:border-neutral-700 dark:bg-bg-secondary-dark"
					data-aos="fade-up-sm"
					data-aos-delay={index * 90}
					data-aos-once="true"
				>
					<div class="mb-4 grid h-10 w-10 place-items-center rounded-lg bg-primary/10 text-primary dark:bg-primary/20 dark:text-primary-light">
						<item.icon class="h-5 w-5" />
					</div>
					<h3 class="mb-2 text-lg font-semibold text-neutral-800 dark:text-neutral-100">{item.title}</h3>
					<p class="text-sm leading-relaxed text-neutral-500 dark:text-neutral-400">{item.desc}</p>
				</article>
			))}
		</div>
	</section>

	<div class="site-container my-4 border-b border-dashed border-neutral-200 dark:border-neutral-700"></div>

	<section class="site-container py-16 md:py-24">
		<div class="grid items-start gap-8 lg:grid-cols-[0.95fr_1.05fr]">
			<div data-aos="fade-up-xs" data-aos-once="true">
				<div class="mb-4 inline-flex items-center gap-2 rounded-md border border-dashed border-primary/25 bg-primary/5 px-3 py-1 text-xs font-medium text-primary">
					<Brush class="h-3.5 w-3.5" /> Theme workflow
				</div>
				<h2 class="mb-4 max-w-xl text-3xl font-brand md:text-4xl">Build from the design, then fill in the product</h2>
				<p class="max-w-2xl text-neutral-600 leading-relaxed dark:text-neutral-300">
					This starter is intentionally quiet: it gives you a polished visual system, a content layer, and a component reference. Your app, brand, product screenshots, and copy can take over from there.
				</p>
				<div class="mt-7 flex flex-wrap gap-3">
					<Button url="/design" type="fill">
						View DESIGN.md <ArrowRight size={16} />
					</Button>
					<Button url="/elements">
						Open Elements
					</Button>
				</div>
			</div>

			<BrowserFrame url="starter/theme-map" className="w-full" data-aos="fade-up-sm">
				<div class="grid gap-3 p-4 md:p-5">
					{fileMap.map((file) => (
						<div class="grid grid-cols-[1fr_auto] items-center gap-4 rounded-lg border border-primary/10 bg-bg-primary/50 px-4 py-3 dark:border-neutral-700 dark:bg-neutral-800/40">
							<div class="flex min-w-0 items-center gap-3">
								<FolderOpen class="h-4 w-4 flex-none text-primary" />
								<span class="truncate font-mono text-xs text-neutral-700 dark:text-neutral-200">{file.path}</span>
							</div>
							<span class="rounded-md bg-primary/5 px-2 py-1 text-[10px] text-primary dark:bg-primary/10 dark:text-primary-light">
								{file.note}
							</span>
						</div>
					))}
				</div>
			</BrowserFrame>
		</div>
	</section>

	<section class="site-container py-16 md:py-24">
		<SectionHeader
			title="A short path from clone to custom site"
			description="Most first edits should happen in four places. The rest of the starter stays out of your way."
		/>
		<div class="mt-8 grid gap-4 md:grid-cols-4">
			{workflow.map((step, index) => (
				<div
					class="rounded-xl border border-dashed border-primary/20 bg-bg-secondary p-5 dark:border-neutral-700 dark:bg-bg-secondary-dark"
					data-aos="fade-up-sm"
					data-aos-delay={index * 80}
					data-aos-once="true"
				>
					<span class="mb-4 inline-flex h-8 w-8 items-center justify-center rounded-md bg-primary text-sm font-semibold text-white">
						{index + 1}
					</span>
					<p class="text-sm font-medium leading-relaxed text-neutral-700 dark:text-neutral-200">{step}</p>
				</div>
			))}
		</div>
	</section>

	<div class="site-container my-4 border-b border-dashed border-neutral-200 dark:border-neutral-700"></div>

	<section class="py-16 md:py-24">
		<BlogSection
			title="Starter notes"
			description="Use the Blog as documentation, release writing, essays, or product updates."
			limit={3}
		/>
	</section>

	<section class="site-container py-12 md:py-20">
		<div class="rounded-xl border border-primary/10 bg-bg-secondary p-7 text-center dark:border-neutral-700 dark:bg-bg-secondary-dark md:p-10">
			<div class="mb-4 flex justify-center">
				<div class="grid h-12 w-12 place-items-center rounded-xl bg-accent/30 text-neutral-800 dark:bg-accent/20 dark:text-neutral-100">
					<Sparkles class="h-5 w-5" />
				</div>
			</div>
			<h2 class="mx-auto mb-4 max-w-2xl text-3xl font-brand md:text-4xl">Start with the theme, ship your own thing</h2>
			<p class="mx-auto mb-7 max-w-2xl text-neutral-600 dark:text-neutral-300">
				Clone the starter, keep the design language, and replace the sample writing with your own project structure and content.
			</p>
			<div class="flex flex-wrap justify-center gap-3">
				<Button url={siteConfig.social.github} type="fill" target="_blank">
					Get Template <ArrowRight size={16} />
				</Button>
				<Button url="/rss.xml">
					<Rss size={16} /> RSS
				</Button>
			</div>
		</div>
	</section>
</Layout>
